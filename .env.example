# Copy this file to .env and fill in all values

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

AUTH_SECRET="replace-with-output-of-npx-auth-secret"
AUTH_TRUST_HOST=true

AUTH_RESEND_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="sweepstakes@yourdomain.com"

API_FOOTBALL_KEY="your_api_football_key"

CRON_SECRET="replace-with-a-long-random-string"

# Public URL of your deployment (used in email links)
APP_URL="https://your-app.vercel.app"

# Comma-separated emails that get ADMIN role on first sign-in
ADMIN_EMAILS="you@yourdomain.com"
